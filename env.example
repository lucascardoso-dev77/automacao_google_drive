# ─── Credenciais Google ───────────────────────────────────────────────────────
# Caminho para o arquivo JSON baixado do Google Cloud Console
GOOGLE_CREDENTIALS_FILE=credentials.json

# Token OAuth2 gerado automaticamente na primeira execução
GOOGLE_TOKEN_FILE=token.json

# ─── Gmail ────────────────────────────────────────────────────────────────────
# Nome da label que contém os emails a processar (crie manualmente no Gmail)
GMAIL_LABEL=PROCESSAR

# Número máximo de emails processados por execução
GMAIL_MAX_RESULTS=50

# ─── Google Drive ─────────────────────────────────────────────────────────────
# Nome da pasta raiz no Google Drive onde os PDFs serão organizados
DRIVE_ROOT_FOLDER_NAME=Documentos

# ─── Diretórios locais ────────────────────────────────────────────────────────
DOWNLOAD_DIR=downloads
OUTPUT_DIR=output
LOG_DIR=logs
DB_PATH=processamentos.db

# ─── Conversão de arquivos ────────────────────────────────────────────────────
# Binário do LibreOffice (geralmente "soffice" no Linux)
LIBREOFFICE_BIN=soffice

# ─── Logging ─────────────────────────────────────────────────────────────────
# Níveis: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
